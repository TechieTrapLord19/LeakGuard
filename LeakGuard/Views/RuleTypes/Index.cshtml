@model IEnumerable<LeakGuard.Models.RuleType>
@{
    ViewData["Title"] = "Rule Types";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Rule Types</h4>
        <p class="text-muted mb-0">Define the categories for your detection rules (e.g. Keyword, Regex, Extension).</p>
    </div>
    <button class="btn btn-primary px-4" data-bs-toggle="modal" data-bs-target="#createTypeModal">
        <i class="bi bi-plus-lg me-2"></i>Add Type
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="glass-panel">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Type Name</th>
                    <th>Rules Using This Type</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">
                            <i class="bi bi-tags fs-3 d-block mb-2"></i>
                            No rule types yet. Create one to start adding detection rules.
                            <br />
                            <span class="small mt-2 d-block">Suggested types: <strong>Keyword</strong>, <strong>Regex</strong>, <strong>File Extension</strong></span>
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted small">@item.RuleTypeID</td>
                        <td>
                            <span class="badge bg-primary bg-opacity-25 text-primary px-3 py-2 rounded-pill">
                                <i class="bi bi-tag me-1"></i>@item.TypeName
                            </span>
                        </td>
                        <td class="text-muted">@(item.Rules?.Count ?? 0) rule(s)</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-secondary me-1"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editTypeModal"
                                    data-id="@item.RuleTypeID"
                                    data-typename="@item.TypeName">
                                <i class="bi bi-pencil"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Quickstart hint -->
@if (!Model.Any())
{
    <div class="mt-4 glass-panel p-4">
        <h6 class="fw-bold mb-3"><i class="bi bi-lightbulb text-warning me-2"></i>Getting Started</h6>
        <p class="text-muted small mb-3">We recommend creating at least these three types to get started:</p>
        <div class="d-flex flex-wrap gap-2">
            <form asp-action="Create" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="TypeName" value="Keyword" />
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-plus me-1"></i>Add "Keyword"
                </button>
            </form>
            <form asp-action="Create" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="TypeName" value="Regex" />
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-plus me-1"></i>Add "Regex"
                </button>
            </form>
            <form asp-action="Create" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="TypeName" value="File Extension" />
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-plus me-1"></i>Add "File Extension"
                </button>
            </form>
        </div>
    </div>
}

<!-- CREATE MODAL -->
<div class="modal fade" id="createTypeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content bg-dark border border-secondary border-opacity-50">
            <div class="modal-header border-secondary border-opacity-25">
                <h5 class="modal-title fw-bold"><i class="bi bi-tag me-2 text-primary"></i>Add Rule Type</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <label class="form-label text-muted small fw-semibold text-uppercase">Type Name</label>
                    <input type="text" name="TypeName" class="form-control" placeholder="e.g. Keyword, Regex, Extension" required autofocus />
                </div>
                <div class="modal-footer border-secondary border-opacity-25">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editTypeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content bg-dark border border-secondary border-opacity-50">
            <div class="modal-header border-secondary border-opacity-25">
                <h5 class="modal-title fw-bold"><i class="bi bi-pencil me-2 text-warning"></i>Edit Rule Type</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="editTypeForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editTypeID" name="RuleTypeID" />
                <div class="modal-body">
                    <label class="form-label text-muted small fw-semibold text-uppercase">Type Name</label>
                    <input type="text" id="editTypeName" name="TypeName" class="form-control" required />
                </div>
                <div class="modal-footer border-secondary border-opacity-25">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning text-dark px-4">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('editTypeModal').addEventListener('show.bs.modal', function (e) {
        const btn = e.relatedTarget;
        const id = btn.getAttribute('data-id');
        document.getElementById('editTypeID').value = id;
        document.getElementById('editTypeName').value = btn.getAttribute('data-typename');
        document.getElementById('editTypeForm').action = `/RuleTypes/Edit/${id}`;
    });
</script>
}
