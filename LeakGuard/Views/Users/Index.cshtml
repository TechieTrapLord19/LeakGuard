@model IEnumerable<LeakGuard.Models.User>
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Users</h4>
        <p class="text-muted mb-0">System accounts and their access roles.</p>
    </div>
    <span class="badge bg-primary bg-opacity-25 text-primary px-3 py-2 rounded-pill fs-6">
        <i class="bi bi-people me-1"></i>@Model.Count() Accounts
    </span>
</div>

<div class="glass-panel">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">
                            <i class="bi bi-people fs-3 d-block mb-2"></i>
                            No users found.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted small">#@item.UserID</td>
                        <td class="fw-semibold">
                            <i class="bi bi-person-circle me-1 text-info"></i>@item.FullName
                        </td>
                        <td class="text-muted">@item.Email</td>
                        <td>
                            @if (item.Role?.RoleName == "Administrator")
                            {
                                <span class="badge bg-primary bg-opacity-25 text-primary"><i class="bi bi-shield-lock me-1"></i>Administrator</span>
                            }
                            else
                            {
                                <span class="badge bg-info bg-opacity-25 text-info"><i class="bi bi-eye me-1"></i>@(item.Role?.RoleName ?? "User")</span>
                            }
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success bg-opacity-25 text-success"><i class="bi bi-circle-fill small me-1"></i>Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-25 text-danger"><i class="bi bi-circle-fill small me-1"></i>Inactive</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
