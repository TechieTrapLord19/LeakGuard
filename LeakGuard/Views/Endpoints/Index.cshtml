@model IEnumerable<LeakGuard.Models.Endpoint>
@{
    ViewData["Title"] = "Endpoints";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Endpoints</h4>
        <p class="text-muted mb-0">Devices monitored by the LeakGuard scanning agent.</p>
    </div>
    <span class="badge bg-primary bg-opacity-25 text-primary px-3 py-2 rounded-pill fs-6">
        <i class="bi bi-pc-display me-1"></i>@Model.Count() Devices
    </span>
</div>

<div class="glass-panel">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Hostname</th>
                    <th>IP Address</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">
                            <i class="bi bi-pc-display fs-3 d-block mb-2"></i>
                            No endpoints registered yet.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted small">#@item.EndpointID</td>
                        <td class="fw-semibold">
                            <i class="bi bi-pc-display me-1 text-info"></i>@item.Hostname
                        </td>
                        <td class="font-monospace text-muted">@(item.IPAddress ?? "N/A")</td>
                        <td><span class="badge bg-success bg-opacity-25 text-success"><i class="bi bi-circle-fill small me-1"></i>Monitored</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
