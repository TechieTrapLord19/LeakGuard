@model LeakGuard.Models.DashboardViewModel
@{
    ViewData["Title"] = "System Overview";
}

<div class="row g-4 mb-4">
    <div class="col-12 col-md-4">
        <div class="glass-panel p-4 h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-1">Total Incidents</h6>
                    <h2 class="mb-0 text-danger fw-bold" id="totalIncidentsCounter">@Model.TotalIncidents</h2>
                </div>
                <div class="bg-danger bg-opacity-25 p-3 rounded-3">
                    <i class="bi bi-shield-slash text-danger fs-4"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-12 col-md-4">
        <div class="glass-panel p-4 h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-1">Active Rules</h6>
                    <h2 class="mb-0 text-primary fw-bold">@Model.ActiveRulesCount</h2>
                </div>
                <div class="bg-primary bg-opacity-25 p-3 rounded-3">
                    <i class="bi bi-journal-check text-primary fs-4"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="glass-panel p-4 h-100">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-1">Monitored Endpoints</h6>
                    <h2 class="mb-0 text-info fw-bold">@Model.MonitoredEndpointsCount</h2>
                </div>
                <div class="bg-info bg-opacity-25 p-3 rounded-3">
                    <i class="bi bi-pc-display text-info fs-4"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12">
        <div class="glass-panel p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="mb-0 fw-bold">Recent Alerts</h5>
                <a asp-controller="Incidents" asp-action="Index" class="btn btn-outline-primary btn-sm">View All</a>
            </div>
            
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Action</th>
                            <th>Endpoint</th>
                            <th>Rule Triggered</th>
                            <th>File Path</th>
                            <th>Time</th>
                        </tr>
                    </thead>
                    <tbody id="recentAlertsBody">
                        @if (Model.RecentIncidents.Count == 0)
                        {
                            <tr data-placeholder="true">
                                <td colspan="5" class="text-center text-muted">No incidents detected yet.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var incident in Model.RecentIncidents)
                            {
                                <tr>
                                    <td>
                                        @if (incident.ActionType != null && incident.ActionType.ActionName == "Quarantined")
                                        {
                                            <span class="badge bg-warning text-dark">@incident.ActionType.ActionName</span>
                                        }
                                        else if (incident.ActionType != null && incident.ActionType.ActionName == "Blocked")
                                        {
                                            <span class="badge bg-danger">@incident.ActionType.ActionName</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info">@(incident.ActionType?.ActionName ?? "Alerted")</span>
                                        }
                                    </td>
                                    <td>@(incident.Endpoint?.Hostname ?? "Unknown")</td>
                                    <td>@(incident.Rule?.RuleName ?? "Unknown Rule")</td>
                                    <td class="text-truncate" style="max-width: 250px;" title="@incident.FilePath">@incident.FilePath</td>
                                    <td>@incident.Timestamp.ToLocalTime().ToString("g")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Live-update the Recent Alerts table when the scanner pushes a new incident.
    // Registered in addition to the toast handler in _Layout.cshtml.
    connection.on("ReceiveIncident", (data) => {
        const tbody = document.getElementById('recentAlertsBody');
        if (!tbody) return;

        // Remove the "No incidents detected yet" placeholder if present
        tbody.querySelector('tr[data-placeholder]')?.remove();

        const time = data.timestamp ? new Date(data.timestamp) : new Date();
        const row = document.createElement('tr');
        row.className = 'live-incident-row';
        row.innerHTML = `
            <td><span class="badge ${actionBadgeClass(data.action)}">${escHtml(data.action)}</span></td>
            <td>${escHtml(data.hostname)}</td>
            <td>${escHtml(data.ruleName)}</td>
            <td class="text-truncate" style="max-width: 250px;" title="${escHtml(data.filePath)}">${escHtml(data.filePath)}</td>
            <td>${time.toLocaleString([], { dateStyle: 'short', timeStyle: 'short' })}</td>
        `;
        tbody.prepend(row);

        // Keep only the 5 most recent alerts, matching the server-rendered view
        while (tbody.rows.length > 5) {
            tbody.deleteRow(tbody.rows.length - 1);
        }
    });
</script>
}
