@model IEnumerable<LeakGuard.Models.Rule>
@{
    ViewData["Title"] = "Detection Rules";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Detection Rules</h4>
        <p class="text-muted mb-0">Manage regex patterns, keywords, and file extension restrictions.</p>
    </div>
    <button class="btn btn-primary px-4" data-bs-toggle="modal" data-bs-target="#createRuleModal">
        <i class="bi bi-plus-lg me-2"></i>Add Rule
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="glass-panel">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th>Rule Name</th>
                    <th>Type</th>
                    <th>Match Value</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">
                            <i class="bi bi-journal-x fs-3 d-block mb-2"></i>
                            No rules configured yet. Add your first detection rule.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr class="@(item.IsActive ? "" : "row-archived")">
                        <td class="fw-semibold">@item.RuleName</td>
                        <td>
                            <span class="badge bg-primary bg-opacity-25 text-primary">@(item.RuleType?.TypeName ?? "N/A")</span>
                        </td>
                        <td><code class="text-info small">@item.MatchValue</code></td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success bg-opacity-25 text-success"><i class="bi bi-circle-fill small me-1"></i>Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-25 text-secondary"><i class="bi bi-archive small me-1"></i>Archived</span>
                            }
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-secondary me-1"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editRuleModal"
                                    data-id="@item.RuleID"
                                    data-rulename="@item.RuleName"
                                    data-ruletypeid="@item.RuleTypeID"
                                    data-actiontypeid="@item.ActionTypeID"
                                    data-matchvalue="@item.MatchValue"
                                    data-isactive="@item.IsActive">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <form asp-action="ToggleActive" asp-route-id="@item.RuleID" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                @if (item.IsActive)
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-warning" title="Archive this rule (stops detection, keeps incident history)">
                                        <i class="bi bi-archive"></i>
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-success" title="Reactivate this rule">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- CREATE MODAL -->
<div class="modal fade" id="createRuleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border border-secondary border-opacity-50">
            <div class="modal-header border-secondary border-opacity-25">
                <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>Add Detection Rule</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold text-uppercase">Rule Name</label>
                        <input type="text" name="RuleName" class="form-control" placeholder="e.g. Credit Card Pattern" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold text-uppercase">Rule Type</label>
                        <select name="RuleTypeID" class="form-select" required>
                            <option value="">-- Select Type --</option>
                            @foreach (var rt in ViewBag.RuleTypes as IEnumerable<LeakGuard.Models.RuleType> ?? Enumerable.Empty<LeakGuard.Models.RuleType>())
                            {
                                <option value="@rt.RuleTypeID">@rt.TypeName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold text-uppercase">Enforcement Action</label>
                        <select name="ActionTypeID" class="form-select">
                            <option value="">-- Select Action (Default: Alert) --</option>
                            @foreach (var at in ViewBag.ActionTypes as IEnumerable<LeakGuard.Models.ActionType> ?? Enumerable.Empty<LeakGuard.Models.ActionType>())
                            {
                                <option value="@at.ActionTypeID">@at.ActionName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold text-uppercase">Match Value (Regex / Keyword / Extension)</label>
                        <input type="text" name="MatchValue" class="form-control font-monospace" placeholder="e.g. \b\d{16}\b or Confidential or .bak,.sql" required />
                        <div class="form-text">For extensions, start with a dot and separate multiple with commas (e.g., <code>.sql, .bak, .docx</code>). For keywords, type the word. For PII, use a Regex pattern.</div>
                    </div>
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" id="createIsActive" checked>
                        <input type="hidden" name="IsActive" value="false" />
                        <label class="form-check-label" for="createIsActive">Active</label>
                    </div>
                </div>
                <div class="modal-footer border-secondary border-opacity-25">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Save Rule</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editRuleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border border-secondary border-opacity-50">
            <div class="modal-header border-secondary border-opacity-25">
                <h5 class="modal-title fw-bold"><i class="bi bi-pencil me-2 text-warning"></i>Edit Rule</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="editRuleForm" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editRuleID" name="RuleID" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold text-uppercase">Rule Name</label>
                        <input type="text" id="editRuleName" name="RuleName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold text-uppercase">Rule Type</label>
                        <select id="editRuleType" name="RuleTypeID" class="form-select" required>
                            @foreach (var rt in ViewBag.RuleTypes as IEnumerable<LeakGuard.Models.RuleType> ?? Enumerable.Empty<LeakGuard.Models.RuleType>())
                            {
                                <option value="@rt.RuleTypeID">@rt.TypeName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold text-uppercase">Enforcement Action</label>
                        <select id="editActionType" name="ActionTypeID" class="form-select">
                            <option value="">-- Select Action (Default: Alert) --</option>
                            @foreach (var at in ViewBag.ActionTypes as IEnumerable<LeakGuard.Models.ActionType> ?? Enumerable.Empty<LeakGuard.Models.ActionType>())
                            {
                                <option value="@at.ActionTypeID">@at.ActionName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-semibold text-uppercase">Match Value</label>
                        <input type="text" id="editMatchValue" name="MatchValue" class="form-control font-monospace" required />
                        <div class="form-text">For extensions, start with a dot and separate multiple extensions by commas (e.g., <code>.sql, .bak, .docx</code>). For keywords, type the word. For PII, use a Regex pattern.</div>
                    </div>
                    <div class="form-check form-switch mb-2">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" id="editIsActive">
                        <input type="hidden" name="IsActive" value="false" />
                        <label class="form-check-label" for="editIsActive">Active</label>
                    </div>
                </div>
                <div class="modal-footer border-secondary border-opacity-25">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning text-dark px-4">Update Rule</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Populate Edit modal
    document.getElementById('editRuleModal').addEventListener('show.bs.modal', function (e) {
        const btn = e.relatedTarget;
        const id = btn.getAttribute('data-id');
        document.getElementById('editRuleID').value = id;
        document.getElementById('editRuleName').value = btn.getAttribute('data-rulename');
        document.getElementById('editRuleType').value = btn.getAttribute('data-ruletypeid');
        document.getElementById('editMatchValue').value = btn.getAttribute('data-matchvalue');
        document.getElementById('editIsActive').checked = btn.getAttribute('data-isactive') === 'True';
        
        const actionType = btn.getAttribute('data-actiontypeid');
        document.getElementById('editActionType').value = actionType ? actionType : "";
        
        document.getElementById('editRuleForm').action = `/Rules/Edit/${id}`;
    });
</script>
}
