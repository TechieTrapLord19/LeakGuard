@model IEnumerable<LeakGuard.Models.AuditLog>
@{
    ViewData["Title"] = "Audit Logs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Audit Logs</h4>
        <p class="text-muted mb-0">Immutable record of every administrative action performed in the system.</p>
    </div>
    <span class="badge bg-primary bg-opacity-25 text-primary px-3 py-2 rounded-pill fs-6">
        <i class="bi bi-list-check me-1"></i>@Model.Count() Entries
    </span>
</div>

<div class="glass-panel">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Timestamp</th>
                    <th>User</th>
                    <th>Action</th>
                    <th>Activity</th>
                    <th>IP Address</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-5">
                            <i class="bi bi-journal-text fs-3 d-block mb-2"></i>
                            No audit entries yet. Administrative actions will be recorded here.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    var verb = (item.Activity ?? "").Split(' ').FirstOrDefault() ?? "";
                    var verbClass = verb switch
                    {
                        "Created" or "Added" or "Enabled" or "Reactivated" => "bg-success bg-opacity-25 text-success",
                        "Updated" => "bg-warning bg-opacity-25 text-warning",
                        "Archived" or "Disabled" => "bg-secondary bg-opacity-25 text-secondary",
                        "Deleted" or "Removed" => "bg-danger bg-opacity-25 text-danger",
                        _ => "bg-info bg-opacity-25 text-info"
                    };
                    <tr>
                        <td class="text-muted small">#@item.AuditLogID</td>
                        <td class="text-muted small">@item.LogTime.ToLocalTime().ToString("MMM dd, yyyy HH:mm:ss")</td>
                        <td>
                            <i class="bi bi-person-circle me-1 text-info"></i>@(item.User?.FullName ?? "Unknown")
                        </td>
                        <td><span class="badge @verbClass">@(string.IsNullOrEmpty(verb) ? "Action" : verb)</span></td>
                        <td>@item.Activity</td>
                        <td class="font-monospace text-muted small">@(item.IPAddress ?? "N/A")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
