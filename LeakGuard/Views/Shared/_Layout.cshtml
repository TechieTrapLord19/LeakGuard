<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LeakGuard Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LeakGuard.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
</head>
<body class="bg-dark text-light font-inter">
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <div class="bg-dark border-end border-secondary border-opacity-25" id="sidebar-wrapper">
            <div class="sidebar-heading text-center py-4 fs-4 fw-bold text-primary tracking-wide d-flex align-items-center justify-content-center">
                <img src="~/images/image.png" alt="" class="img-fluid me-3" style="height: 65px; object-fit: contain;" />
                <span>LeakGuard</span>
            </div>
            <div class="list-group list-group-flush px-3">
                <a class="list-group-item list-group-item-action bg-transparent text-light border-0 rounded-3 mb-1" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door me-2"></i>Overview
                </a>
                <a class="list-group-item list-group-item-action bg-transparent text-light border-0 rounded-3 mb-1" asp-controller="Incidents" asp-action="Index">
                    <i class="bi bi-exclamation-triangle me-2 text-danger"></i>Incidents
                </a>
                @if (User.IsInRole("Administrator"))
                {
                    <a class="list-group-item list-group-item-action bg-transparent text-light border-0 rounded-3 mb-1" asp-controller="Rules" asp-action="Index">
                        <i class="bi bi-journal-code me-2"></i>Detection Rules
                    </a>
                    <a class="list-group-item list-group-item-action bg-transparent text-light border-0 rounded-3 mb-1" asp-controller="RuleTypes" asp-action="Index">
                        <i class="bi bi-tags me-2"></i>Rule Types
                    </a>
                    <a class="list-group-item list-group-item-action bg-transparent text-light border-0 rounded-3 mb-1" asp-controller="MonitoredDirectories" asp-action="Index">
                        <i class="bi bi-folder2-open me-2"></i>Directories
                    </a>
                    <a class="list-group-item list-group-item-action bg-transparent text-light border-0 rounded-3 mb-1" asp-controller="Users" asp-action="Index">
                        <i class="bi bi-people me-2"></i>Users
                    </a>
                    <a class="list-group-item list-group-item-action bg-transparent text-light border-0 rounded-3 mb-1" asp-controller="Endpoints" asp-action="Index">
                        <i class="bi bi-pc-display me-2"></i>Endpoints
                    </a>
                    <a class="list-group-item list-group-item-action bg-transparent text-light border-0 rounded-3 mb-1" asp-controller="AuditLogs" asp-action="Index">
                        <i class="bi bi-list-check me-2"></i>Audit Logs
                    </a>
                }
            </div>
        </div>
        
        <!-- Page Content -->
        <div id="page-content-wrapper" class="w-100">
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary border-opacity-25 py-3 px-4">
                <div class="d-flex align-items-center justify-content-between w-100">
                    <h5 class="mb-0 fw-semibold text-light">@ViewData["Title"]</h5>
                    <div class="d-flex align-items-center">
                        <span class="badge bg-success bg-opacity-25 text-success rounded-pill px-3 py-2 me-3" id="systemStatusBadge">
                            <i class="bi bi-circle-fill small me-1"></i> <span id="systemStatusText">Connecting...</span>
                        </span>
                        <div class="dropdown">
                            <a class="text-light text-decoration-none dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle fs-5"></i> @(User.Identity?.Name ?? "Admin")
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark">
                                <li><a class="dropdown-item" href="#">Profile</a></li>
                                <li><a class="dropdown-item" href="#">Settings</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout">Logout</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="container-fluid p-4 dashboard-content">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        <!-- Toast Container for Live Alerts -->
        <div class="toast-container position-fixed bottom-0 end-0 p-3" id="liveAlertContainer">
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        // Escape untrusted values (file paths, matched file content) before inserting into HTML
        function escHtml(value) {
            const div = document.createElement('div');
            div.textContent = value ?? '';
            return div.innerHTML;
        }

        function actionBadgeClass(action) {
            return action === 'Quarantined' ? 'bg-warning text-dark' :
                   action === 'Blocked' ? 'bg-danger' : 'bg-info text-dark';
        }

        function setSystemStatus(connected, label) {
            const badge = document.getElementById('systemStatusBadge');
            const text = document.getElementById('systemStatusText');
            if (!badge || !text) return;
            badge.className = `badge rounded-pill px-3 py-2 me-3 ${connected ? 'bg-success bg-opacity-25 text-success' : 'bg-danger bg-opacity-25 text-danger'}`;
            text.textContent = label;
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/incidentHub")
            .withAutomaticReconnect()
            .build();

        connection.onreconnecting(() => setSystemStatus(false, 'Reconnecting...'));
        connection.onreconnected(() => setSystemStatus(true, 'System Active'));
        connection.onclose(() => setSystemStatus(false, 'Offline'));

        connection.on("ReceiveIncident", (data) => {
            console.log("Live Incident Received:", data);

            const badgeColor = actionBadgeClass(data.action);
            const fileName = (data.filePath || '').split(/[\\/]/).pop();
            const detectedAt = (data.timestamp ? new Date(data.timestamp) : new Date())
                .toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

            const toastHtml = `
                <div class="toast leakguard-toast" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="12000">
                    <div class="d-flex align-items-start p-3">
                        <div class="leakguard-toast-icon me-3">
                            <i class="bi bi-shield-exclamation"></i>
                        </div>
                        <div class="flex-grow-1 overflow-hidden">
                            <div class="d-flex align-items-center mb-1">
                                <strong class="text-danger me-auto" style="letter-spacing:0.5px;">LEAK DETECTED</strong>
                                <small class="text-muted ms-2">${detectedAt}</small>
                                <button type="button" class="btn-close btn-close-white ms-2" data-bs-dismiss="toast" aria-label="Close"></button>
                            </div>
                            <div class="fs-6 fw-bold text-white text-truncate" title="${escHtml(data.filePath)}">
                                <i class="bi bi-file-earmark-text text-warning me-1"></i>${escHtml(fileName)}
                            </div>
                            <div class="small text-muted text-truncate mb-2" title="${escHtml(data.filePath)}">${escHtml(data.filePath)}</div>
                            <div class="d-flex flex-wrap gap-2 align-items-center">
                                <span class="badge ${badgeColor}">${escHtml(data.action)}</span>
                                <span class="badge bg-primary bg-opacity-25 text-primary">${escHtml(data.ruleName)}</span>
                                <span class="small text-muted"><i class="bi bi-pc-display me-1"></i>${escHtml(data.hostname)}</span>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            
            const container = document.getElementById('liveAlertContainer');
            container.insertAdjacentHTML('beforeend', toastHtml);
            
            const toastEl = container.lastElementChild;
            const toast = new bootstrap.Toast(toastEl);
            toast.show();
            
            // Play alert sound (optional, assuming user has system sound)
            try { new Audio('data:audio/wav;base64,UklGRl9vT19XQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YU...').play(); } catch(e){}
            
            // Increment total incidents counter if on dashboard
            const counter = document.getElementById('totalIncidentsCounter');
            if(counter) {
                counter.innerText = parseInt(counter.innerText) + 1;
                counter.classList.add('text-danger');
                setTimeout(() => counter.classList.remove('text-danger'), 1000);
            }
        });

        connection.start()
            .then(() => setSystemStatus(true, 'System Active'))
            .catch(err => { setSystemStatus(false, 'Offline'); console.error(err.toString()); });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
